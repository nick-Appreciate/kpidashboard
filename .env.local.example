# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (for API routes only - keep secret!)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Bot scraper endpoints on VPS
APPFOLIO_BOT_URL=http://your-vps-ip:3100
APPFOLIO_BOT_SECRET=your-appfolio-bot-api-secret
BPU_BOT_URL=http://your-vps-ip:3101
BPU_BOT_SECRET=your-bpu-bot-api-secret
