# BPU Bot Server Configuration

# Port the server listens on
PORT=3101

# Secret token for API authentication (used in Authorization: Bearer header)
# Generate with: openssl rand -hex 32
API_SECRET=changeme

# BPU login credentials
BPU_USERNAME=
BPU_PASSWORD=

# Supabase (for uploading parsed meter readings)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
